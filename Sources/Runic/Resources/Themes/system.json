{
  "id": "system",
  "displayName": "System",
  "tagline": "Follow macOS",
  "symbolName": "circle.lefthalf.filled",
  "isCustom": false,
  "prefersDarkAppearance": null,
  "colors": {
    "primary":       "$controlAccentColor",
    "secondary":     "#4288F5",
    "accent":        "$controlAccentColor",
    "highlight":     "#F0872E",
    "warm":          "#CC73EB",
    "tertiary":      "#42C7DB",
    "surface":       "$windowBackgroundColor",
    "surfaceAlt":    "$controlBackgroundColor",
    "cardFill":      "$controlBackgroundColor@0.34",
    "cardStroke":    "$separatorColor@0.35",
    "primaryText":   "$controlTextColor",
    "secondaryText": "$secondaryLabelColor"
  },
  "fonts":   { "body": "system", "numeric": "system" },
  "shape":   { "preset": "standard" },
  "motion":  { "preset": "standard" },
  "density": { "preset": "normal" },
  "style": {
    "typography": { "bodyFamily": "__sf_pro__", "numericFamily": "__sf_mono__", "scale": 1.03, "tracking": 0.0, "contrast": "strong" },
    "chrome": { "borderStyle": "native", "borderWeight": 0.7, "borderOpacity": 0.52, "cornerStyle": "standard", "panelDepth": "medium" },
    "effects": { "scanlineOpacity": 0.0, "glowStrength": 0.12, "materialIntensity": 0.34 },
    "controls": { "selectedFillStyle": "accentSoft", "progressStyle": "softBar", "hoverStyle": "accent" }
  }
}
